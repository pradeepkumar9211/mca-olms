# Automatically normalize line endings across platforms
* text=auto eol=lf

# Explicitly set text files to use LF (Linux/Unix style)
*.js   text eol=lf
*.json text eol=lf
*.ts   text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.env  text eol=lf

# Windows-specific files should keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Linux-specific files should keep CRLF
*.sh text eol=lf

# Binary files - don't touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.mp4  binary
*.mov  binary
*.mp3  binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lock these files so they don’t get normalized
*.lock binary
package-lock.json text eol=lf